{
  "name": "oke-front-mcp",
  "version": "0.3.0",
  "description": "프론트엔드 개발 통합 MCP 서버 - Figma, 퍼블 레포, Confluence, Ant Vue 통합 (경량화 + 지연 로딩)",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "oke-front-mcp": "./dist/index.js"
  },
  "scripts": {
    "test:figma": "node test-figma.js",
    "build": "tsc && npm run sync-mcp-descriptors",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "collect-metadata": "tsx src/scripts/collect-metadata.ts",
    "build:publisher-taxonomy": "tsx src/scripts/build-publisher-taxonomy.ts",
    "sync-mcp-descriptors": "tsx src/scripts/sync-mcp-descriptors.ts",
    "sync:cursor": "node scripts/sync-to-cursor.mjs",
    "build:dev": "npm run build && npm run sync:cursor",
    "qa:step1-3": "node scripts/qa-step1-3.mjs"
  },
  "keywords": [
    "mcp",
    "figma",
    "frontend",
    "development",
    "cursor"
  ],
  "author": "Okestro Frontend Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.4.5",
    "axios": "^1.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
